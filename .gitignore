# ============================================================
# Cognitive Architecture — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Reference projects (design inspiration, not our code) ---
AutoAgent-main/
AutoHarness-main/
MiroFish-main/
autoresearch-master*/
deep_rl_zoo-main*/
hermes-agent-main/
meta-harness-tbench2-artifact-main/
HyperAgents/
HyperAgents-main/
self_improving_coding_agent/
SICA/

# --- Runtime state (not committed — use resume to transfer) ---
# .pipeline/projects/ is intentionally tracked so cloud instances can git pull
.pipeline/queues/
.pipeline/logs/
.pipeline/state/pipeline_status.json
.pipeline/state/agent_registry.json
.pipeline/state/throughput.json
.pipeline/pipeline_extract*/
.agent/
experiments.tsv
state_*.tar.gz

# --- Generated pipeline runtime data (high-churn, not source) ---
.pipeline/projects/freelancetask_manager_system/workspace/opportunity_pipelines/
.pipeline/projects/*/workspace/**/*.log
.pipeline/projects/*/workspace/**/*.db
.pipeline/projects/*/workspace/submission_log.csv
.pipeline/projects/*/workspace/data/**/*.json

# --- Test artifacts ---
.pytest_cache/
test_output.txt
htmlcov/
.coverage

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Model weights (never commit these) ---
*.bin
*.gguf
*.safetensors
*.onnx

# --- Downloaded benchmark datasets (fetched at setup time, not in git) ---
benchmarks/datasets/

# --- Scratch test scripts ---
test_load_tasks.py
