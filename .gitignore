# ============================================================
# Cognitive Architecture — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Reference projects (design inspiration, not our code) ---
AutoAgent-main/
AutoHarness-main/
MiroFish-main/
autoresearch-master*/
deep_rl_zoo-main*/
hermes-agent-main/
meta-harness-tbench2-artifact-main/
HyperAgents/
HyperAgents-main/
self_improving_coding_agent/
SICA/

# --- Pipeline output (separate repo: ../thepipeline → avatardebris-debug/pipeline) ---
# Factory resolves output via PIPELINE_DIR env or ../thepipeline when present.
.pipeline/

# --- Runtime / local-only (factory repo) ---
.agent/
experiments.tsv
state_*.tar.gz

# --- Test artifacts ---
.pytest_cache/
test_output.txt
htmlcov/
.coverage

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Model weights (never commit these) ---
*.bin
*.gguf
*.safetensors
*.onnx

# --- Downloaded benchmark datasets (fetched at setup time, not in git) ---
benchmarks/datasets/

# --- Scratch test scripts ---
test_load_tasks.py
