# Never commit node_modules or build artifacts
**/node_modules/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/*.egg-info/
**/dist/
**/build/
**/.venv/
**/.env

# Never commit double-nested .pipeline inside .pipeline
.pipeline/

# Logs (large, not needed for resume)
logs/
*.log

# Runtime-generated timestamped data files (e.g. report_20260430_123456.json)
# These are produced by tools running during validation — not source code
**/data/analytics/report_*.json
