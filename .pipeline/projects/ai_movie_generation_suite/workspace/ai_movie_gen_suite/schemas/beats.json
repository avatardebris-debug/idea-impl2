{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BeatSheet",
  "description": "Save-the-Cat beat sheet with 15 beats.",
  "type": "object",
  "required": ["logline", "genre", "beats"],
  "properties": {
    "logline": {"type": "string"},
    "genre": {"type": "string"},
    "beats": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["beat_name", "beat_number", "summary", "description"],
        "properties": {
          "beat_name": {"type": "string"},
          "beat_number": {"type": "integer", "minimum": 1, "maximum": 15},
          "summary": {"type": "string"},
          "description": {"type": "string"},
          "characters_involved": {"type": "array", "items": {"type": "string"}},
          "estimated_page_range": {"type": "string"},
          "phase": {"type": "string", "enum": ["setup", "confrontation", "resolution"]},
          "scene_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
