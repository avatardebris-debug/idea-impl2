{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "description": "Top-level project metadata for an AI movie generation project.",
  "type": "object",
  "required": ["project_id", "title", "logline", "genre"],
  "properties": {
    "project_id": {"type": "string"},
    "title": {"type": "string"},
    "logline": {"type": "string"},
    "genre": {"type": "string"},
    "tone": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "beat_sheet": {"$ref": "#/definitions/BeatSheet"},
    "character_registry": {"$ref": "#/definitions/CharacterRegistry"},
    "script": {"$ref": "#/definitions/Script"},
    "scene_descriptions": {"$ref": "#/definitions/SceneDescriptionCollection"}
  },
  "definitions": {
    "BeatSheet": {
      "type": "object",
      "required": ["logline", "genre", "beats"],
      "properties": {
        "logline": {"type": "string"},
        "genre": {"type": "string"},
        "beats": {
          "type": "array",
          "items": {"$ref": "#/definitions/Beat"}
        }
      }
    },
    "Beat": {
      "type": "object",
      "required": ["beat_name", "beat_number", "summary", "description"],
      "properties": {
        "beat_name": {"type": "string"},
        "beat_number": {"type": "integer"},
        "summary": {"type": "string"},
        "description": {"type": "string"},
        "characters_involved": {"type": "array", "items": {"type": "string"}},
        "estimated_page_range": {"type": "string"},
        "phase": {"type": "string", "enum": ["setup", "confrontation", "resolution"]},
        "scene_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "CharacterRegistry": {
      "type": "object",
      "properties": {
        "characters": {
          "type": "array",
          "items": {"$ref": "#/definitions/Character"}
        }
      }
    },
    "Character": {
      "type": "object",
      "required": ["id", "name", "role", "physical_description"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "role": {"type": "string", "enum": ["protagonist", "antagonist", "mentor", "ally", "sidekick", "deus_ex_machina", "supporting"]},
        "physical_description": {"type": "string"},
        "personality_traits": {"type": "array", "items": {"type": "string"}},
        "voice_notes": {"type": "string"},
        "costume_notes": {"type": "string"},
        "visual_anchor": {"type": "string"},
        "backstory": {"type": "string"},
        "arc_summary": {"type": "string"}
      }
    },
    "Script": {
      "type": "object",
      "required": ["title", "logline", "genre", "scenes"],
      "properties": {
        "title": {"type": "string"},
        "logline": {"type": "string"},
        "genre": {"type": "string"},
        "scenes": {
          "type": "array",
          "items": {"$ref": "#/definitions/Scene"}
        }
      }
    },
    "Scene": {
      "type": "object",
      "required": ["scene_id", "scene_heading", "action"],
      "properties": {
        "scene_id": {"type": "string"},
        "scene_heading": {"type": "string"},
        "action": {"type": "string"},
        "characters_present": {"type": "array", "items": {"type": "string"}},
        "dialogue_lines": {
          "type": "array",
          "items": {"$ref": "#/definitions/DialogueLine"}
        },
        "estimated_page_range": {"type": "string"},
        "beat_ref": {"type": "string"}
      }
    },
    "DialogueLine": {
      "type": "object",
      "required": ["character_name", "character_id", "text"],
      "properties": {
        "character_name": {"type": "string"},
        "character_id": {"type": "string"},
        "text": {"type": "string"},
        "parenthetical": {"type": "string"},
        "delivery": {"type": "string"}
      }
    },
    "SceneDescriptionCollection": {
      "type": "object",
      "properties": {
        "descriptions": {
          "type": "object",
          "additionalProperties": {"$ref": "#/definitions/SceneDescription"}
        }
      }
    },
    "SceneDescription": {
      "type": "object",
      "required": ["scene_id", "setting", "lighting", "camera_notes", "mood"],
      "properties": {
        "scene_id": {"type": "string"},
        "setting": {"type": "string"},
        "lighting": {"type": "string"},
        "camera_notes": {"type": "string"},
        "mood": {"type": "string"},
        "action_beats": {"type": "array", "items": {"type": "string"}},
        "visual_style": {"type": "string"}
      }
    }
  }
}
