{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Script",
  "description": "FDX-compatible screenplay structure.",
  "type": "object",
  "required": ["title", "logline", "genre", "scenes"],
  "properties": {
    "title": {"type": "string"},
    "logline": {"type": "string"},
    "genre": {"type": "string"},
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_id", "scene_heading", "action"],
        "properties": {
          "scene_id": {"type": "string"},
          "scene_heading": {"type": "string", "pattern": "^(INT|EXT|INT/EXT)\\."},
          "action": {"type": "string"},
          "characters_present": {"type": "array", "items": {"type": "string"}},
          "dialogue_lines": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["character_name", "character_id", "text"],
              "properties": {
                "character_name": {"type": "string"},
                "character_id": {"type": "string"},
                "text": {"type": "string"},
                "parenthetical": {"type": "string"},
                "delivery": {"type": "string"}
              }
            }
          },
          "estimated_page_range": {"type": "string"},
          "beat_ref": {"type": "string"}
        }
      }
    }
  }
}
