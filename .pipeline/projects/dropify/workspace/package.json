{
  "name": "dropify",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "admin",
    "storefront"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:admin": "npm run dev --workspace=admin",
    "dev:storefront": "npm run dev --workspace=storefront",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:storefront\"",
    "build": "npm run build --workspaces --if-present",
    "migrate": "cd api && npx prisma migrate dev",
    "generate": "cd api && npx prisma generate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
