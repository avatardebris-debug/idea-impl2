<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ episode_title | default("Podcast Episode") }}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; max-width: 800px; margin: 0 auto; padding: 20px; color: #333; }
        h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 10px; }
        h2 { color: #2980b9; margin-top: 30px; }
        .summary { background: #f8f9fa; padding: 15px; border-left: 4px solid #3498db; border-radius: 4px; }
        .takeaways ul { list-style-type: disc; padding-left: 20px; }
        .anchors ul { list-style-type: none; padding-left: 0; }
        .anchors li { padding: 8px 0; border-bottom: 1px solid #eee; }
        .tags ul { list-style-type: none; padding-left: 0; display: flex; flex-wrap: wrap; gap: 8px; }
        .tags li { background: #e8f4fd; padding: 4px 12px; border-radius: 16px; font-size: 0.9em; }
        .cta { background: #eafaf1; padding: 15px; border-left: 4px solid #27ae60; border-radius: 4px; margin-top: 20px; }
    </style>
</head>
<body>
    <h1>{{ episode_title | default("Podcast Episode") }}</h1>

    {% if episode_description %}
    <p class="summary"><em>{{ episode_description }}</em></p>
    {% endif %}

    <h2>Episode Summary</h2>
    <div class="summary">{{ episode_summary }}</div>

    <h2>Key Takeaways</h2>
    <div class="takeaways">
        <ul>
        {% for takeaway in key_takeaways %}
            <li>{{ takeaway }}</li>
        {% endfor %}
        </ul>
    </div>

    <h2>Timestamped Keyword Anchors</h2>
    <div class="anchors">
        <ul>
        {% for anchor in timestamped_anchors %}
            <li><strong>{{ anchor.keyword }}</strong> — {{ anchor.timestamp }}</li>
        {% endfor %}
        </ul>
    </div>

    <h2>Related Topics / Tags</h2>
    <div class="tags">
        <ul>
        {% for tag in related_tags %}
            <li>{{ tag }}</li>
        {% endfor %}
        </ul>
    </div>

    <h2>Call to Action</h2>
    <div class="cta">{{ cta_text | default("Subscribe and rate this podcast on your favorite platform!") }}</div>
</body>
</html>
