<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ episode_title | default("Show Notes") }}</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            color: #333;
        }
        h1 { color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 0.5rem; }
        h2 { color: #2980b9; margin-top: 2rem; }
        h3 { color: #34495e; }
        .summary { background: #f8f9fa; padding: 1.5rem; border-left: 4px solid #3498db; border-radius: 4px; }
        .takeaways { background: #fff3cd; padding: 1.5rem; border-left: 4px solid #ffc107; border-radius: 4px; }
        .timestamps { background: #e8f5e9; padding: 1.5rem; border-left: 4px solid #4caf50; border-radius: 4px; }
        .topics { background: #f3e5f5; padding: 1.5rem; border-left: 4px solid #9c27b0; border-radius: 4px; }
        .cta { background: #e3f2fd; padding: 1.5rem; border-left: 4px solid #2196f3; border-radius: 4px; }
        ul { padding-left: 1.5rem; }
        li { margin-bottom: 0.5rem; }
        .score { color: #7f8c8d; font-size: 0.9em; }
        footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #ddd; color: #7f8c8d; }
    </style>
</head>
<body>
    <h1>{{ episode_title | default("Podcast Show Notes") }}</h1>

    {% if 'summary' in sections %}
    <section class="summary">
        <h2>Episode Summary</h2>
        <p>{{ sections.summary }}</p>
    </section>
    {% endif %}

    {% if 'key_takeaways' in sections %}
    <section class="takeaways">
        <h2>Key Takeaways</h2>
        <ul>
        {% for item in sections.key_takeaways.split('\n') %}
            {% if item.strip() %}
            <li>{{ item.lstrip('- ') | safe }}</li>
            {% endif %}
        {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if 'timestamps' in sections %}
    <section class="timestamps">
        <h2>Timestamps</h2>
        <ul>
        {% for item in sections.timestamps.split('\n') %}
            {% if item.strip() %}
            <li>{{ item.lstrip('- ') | safe }}</li>
            {% endif %}
        {% endfor %}
        </ul>
    </section>
    {% endif %}

    {% if 'related_topics' in sections %}
    <section class="topics">
        <h2>Related Topics</h2>
        {{ sections.related_topics | safe }}
    </section>
    {% endif %}

    {% if 'cta' in sections %}
    <section class="cta">
        <h2>Call to Action</h2>
        <p>{{ sections.cta }}</p>
    </section>
    {% endif %}

    <footer>
        <p>Generated by PodcastSEO Metadata Optimizer</p>
    </footer>
</body>
</html>
