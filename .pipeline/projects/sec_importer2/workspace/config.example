# SEC Importer API Configuration
# Copy this file to .env and modify as needed

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Database
DB_PATH=sec_importer.db

# Tickers
TICKERS_FILE=tickers.csv

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=*

# API Metadata
API_TITLE=SEC Importer API
API_VERSION=0.1.0
API_DESCRIPTION=REST API for querying SEC EDGAR filing data.

# Pagination
MAX_LIMIT=500
DEFAULT_LIMIT=50

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Caching
CACHE_TTL_SECONDS=300
